{
  "name": "edgeos",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "pnpm --filter backoffice dev",
    "dev:portal": "pnpm --filter portal dev",
    "dev:all": "pnpm --parallel --filter backoffice --filter portal dev",
    "lint": "pnpm --filter backoffice --filter portal lint",
    "lint:portal": "pnpm --filter portal lint",
    "build": "pnpm --filter backoffice --filter portal build",
    "check": "concurrently --kill-others-on-fail -n be,bo,po,e2e -c blue,cyan,magenta,yellow \"pnpm:check:backend\" \"pnpm:check:backoffice\" \"pnpm:check:portal\" \"pnpm:check:e2e\"",
    "check:backend": "cd backend && uv run ruff check . && uv run pytest -q",
    "check:backoffice": "pnpm --filter backoffice exec biome ci . && pnpm --filter backoffice exec tsc -p tsconfig.build.json --noEmit",
    "check:portal": "pnpm --filter portal exec biome ci . && pnpm --filter portal exec tsc --noEmit",
    "check:e2e": "pnpm --filter e2e test"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["@swc/core", "esbuild"]
  }
}
